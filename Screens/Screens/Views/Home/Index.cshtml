@model List<Screens.Models.Image>

<link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;600;700&display=swap" rel="stylesheet">

<style>
    body {
        font-family: 'Cairo', sans-serif;
        direction: rtl;
        background: #f4f6f9;
        margin: 0;
    }

    /* Tabs */
    .tabs {
        display: flex;
        gap: 10px;
        padding: 20px;
        flex-wrap: wrap;
    }

    .tab {
        padding: 8px 16px;
        border-radius: 20px;
        background: #eee;
        text-decoration: none;
        color: #333;
        font-weight: 600;
        transition: 0.3s;
    }

        .tab:hover {
            background: #122e59;
            color: white;
        }

        .tab.active {
            background: #122e59;
            color: white;
        }

    /* Header */
    .header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 0 20px;
    }

    .add-btn {
        background: #122e59;
        color: white;
        padding: 10px 15px;
        border-radius: 6px;
        text-decoration: none;
    }

    /* Gallery */
    .gallery {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(230px, 1fr));
        gap: 20px;
        padding: 20px;
    }

    /* Card */
    .card {
        position: relative;
        border-radius: 15px;
        overflow: hidden;
        background: white;
        box-shadow: 0 5px 15px rgba(0,0,0,0.1);
        transition: 0.3s;
    }

        .card:hover {
            transform: translateY(-5px);
        }

        .card img {
            width: 100%;
            height: 180px;
            object-fit: cover;
        }

    /* Overlay */
    .overlay {
        position: absolute;
        bottom: 0;
        width: 100%;
        padding: 10px;
        background: linear-gradient(transparent, rgba(0,0,0,0.7));
        color: white;
    }

    .actions {
        display: flex;
        justify-content: space-between;
        margin-top: 8px;
    }

        .actions a {
            padding: 5px 10px;
            border-radius: 6px;
            font-size: 13px;
            text-decoration: none;
            color: white;
        }

    .edit-btn {
        background: #0d6efd;
    }

    .delete-btn {
        background: #e74c3c;
    }
</style>


<div class="tabs">
    @foreach (var s in ViewBag.Screens)
    {
        <a href="/Home/Index?screenID=@s.screenId"
           class="tab @(ViewBag.SelectedScreen == s.screenId ? "active" : "")">
            @s.screenName
        </a>
    }
</div>

<!-- Header -->
<div class="header">
    <h2>معرض الصور</h2>
    <a asp-action="Create" class="add-btn">+ إضافة صورة</a>
</div>

<!-- Gallery -->
<div class="gallery">
    @foreach (var item in Model)
    {
        <div class="card">
            <img src="@item.imageBath" />

            <div class="overlay">
                <div>@item.imageTitle</div>
                <small>@item.screen?.screenName</small>

                <div class="actions">
                    <a href="#" class="delete-btn" onclick="confirmDelete(@item.imageID)">حذف</a>

                    <a asp-action="Edit"
                       asp-route-id="@item.imageID"
                       class="edit-btn">
                        تعديل
                    </a>
                </div>
            </div>
        </div>
    }
</div>

<!-- Modal -->
<div class="modal fade" id="deleteModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5>تأكيد الحذف</h5>
            </div>
            <div class="modal-body">
                هل أنت متأكد؟
            </div>
            <div class="modal-footer">
                <button data-bs-dismiss="modal">لا</button>
                <button onclick="deleteItem()">نعم</button>
            </div>
        </div>
    </div>
</div>

<script>
    let deleteId = null;

    function confirmDelete(id) {
        deleteId = id;
        var modal = new bootstrap.Modal(document.getElementById('deleteModal'));
        modal.show();
    }

    function deleteItem() {
        window.location.href = "/Home/Delete/" + deleteId;
    }
</script>
