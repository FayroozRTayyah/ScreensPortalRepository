@model List<Screens.Models.Image>



<style>
    /* body {
        font-family: 'Cairo', sans-serif;
        direction: rtl;
        background: #f5f7fb;
        margin: 0;
    } */

    /* ===== TOP BAR ===== */
    .topbar {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 20px;
    }

    .title {
        font-size: 22px;
        font-weight: 700;
        color: #1e2a38;
    }

    .add-btn {
        background: linear-gradient(135deg, #122e59, #dc3545);
        color: white;
        padding: 10px 18px;
        border-radius: 10px;
        text-decoration: none;
        font-weight: 600;
        transition: 0.3s;
        margin-right: auto;
       
    }

        .add-btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 15px rgba(0,0,0,0.2);
        }

    /* ===== TABS ===== */


    .tab {
        padding: 8px 14px;
        border-radius: 12px;
        background: #e9eef7;
        color: #333;
        text-decoration: none;
        font-weight: 600;
        transition: 0.3s;
        border: 1px solid transparent;
    }

    .tabs-wrapper {
        display: flex;
        align-items: center;
        padding: 0 20px 20px;
    }

    .tabs {
        display: flex;
        gap: 10px;
        flex-wrap: wrap;
    }

        .tab:hover {
            background: #122e59;
            color: #fff;
        }

        .tab.active {
            background: #122e59;
            color: white;
        }

    /* ===== GRID ===== */
    .gallery {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
        gap: 18px;
        padding: 20px;
    }

    /* ===== CARD ===== */
    .card {
        border-radius: 16px;
        overflow: hidden;
        background: #fff;
        box-shadow: 0 8px 25px rgba(0,0,0,0.06);
        transition: 0.3s;
        position: relative;
    }

        .card:hover {
            transform: translateY(-6px);
            box-shadow: 0 12px 30px rgba(0,0,0,0.12);
        }

        .card img {
            width: 100%;
            height: 200px;
            object-fit: cover;
        }

    /* ===== INFO ===== */
    .info {
        padding: 12px;
    }

        .info h4 {
            margin: 0;
            font-size: 16px;
            color: #1e2a38;
        }

        .info small {
            color: #777;
        }

    /* ===== ACTIONS ===== */
    .actions {
        display: flex;
        justify-content: space-between;
        margin-top: 10px;
    }

        .actions a {
            padding: 6px 10px;
            border-radius: 8px;
            font-size: 13px;
            text-decoration: none;
            color: white;
            transition: 0.3s;
        }

    .edit-btn {
        background: #0d6efd;
    }

        .edit-btn:hover {
            background: #0b5ed7;
        }

    .delete-btn {
        background: #e74c3c;
    }

        .delete-btn:hover {
            background: #c0392b;
        }

    /* ===== MODAL ===== */
    .modal-content {
        border-radius: 12px;
    }

    .screen-name {
        color: #ffd700; /* ذهبي */
        font-weight: bold;
    }
</style>

@if (TempData["SuccessMessage"] != null)
{
    var msg = TempData["SuccessMessage"]?.ToString();
    TempData.Remove("SuccessMessage");

    <div class="position-fixed top-0 end-0 p-3" style="z-index: 11">
        <div id="successToast" class="toast align-items-center text-white bg-success border-0">
            <div class="d-flex">
                <div class="toast-body">
                    @msg
                </div>
                <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button>
            </div>
        </div>
    </div>
}



<!-- TOP BAR -->
<div class="topbar">
    <div class="title">🖼️ معرض الصور</div>

    @* <a asp-action="Create"
       asp-route-screenID="@ViewBag.SelectedScreen"
       class="add-btn">
        + إضافة صورة
    </a> *@
</div>

<!-- TABS -->
<div class="tabs-wrapper">

    <div class="tabs">
        @foreach (var s in ViewBag.Screens)
        {
            <a href="/Home/Index?screenID=@s.screenId"
               class="tab @(ViewBag.SelectedScreen == s.screenId ? "active" : "")">
                @s.screenName
            </a>
        }
       
    </div>


   

</div>
@{
    var selectedName = "";
    foreach (var s in ViewBag.Screens)
    {
        if (ViewBag.SelectedScreen == s.screenId)
        {
            selectedName = s.screenName;
            break;
        }
    }
}

<!-- GALLERY -->
<div class="mt-5 mb-3 ">
    <a asp-action="Create"
       asp-route-screenID="@ViewBag.SelectedScreen"
       class="add-btn">
        إضافة صورة على شاشة
        <span class="screen-name">@selectedName</span>
    </a>
</div>


<div class="gallery">
    @foreach (var item in Model)
    {
        <div class="card">
            <img src="@item.imageBath" />

            <div class="info">
                <h4>@item.imageTitle</h4>
                <small>@item.screen?.screenName</small>

                <div class="actions">
                    <a href="#" class="delete-btn" onclick="confirmDelete(@item.imageID)">حذف</a>

                    <a asp-action="Edit"
                       asp-route-id="@item.imageID"
                       class="edit-btn">
                        تعديل
                    </a>
                </div>
            </div>
        </div>
    }

   
</div>



<!-- MODAL -->
<div class="modal fade" id="deleteModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content p-3">
            <h5>تأكيد الحذف</h5>
            <p>هل أنت متأكد من حذف الصورة؟</p>

            <div class="d-flex justify-content-end gap-2">
                <button class="btn btn-secondary" data-bs-dismiss="modal">لا</button>
                <button class="btn btn-danger" onclick="deleteItem()">نعم</button>
            </div>
        </div>
    </div>
</div>

<script>
    let deleteId = null;

    function confirmDelete(id) {
        deleteId = id;
        new bootstrap.Modal(document.getElementById('deleteModal')).show();
    }

    function deleteItem() {
        window.location.href = "/Home/Delete/" + deleteId;
    }
</script>


<script>
        document.addEventListener("DOMContentLoaded", function () {

        // إذا الصفحة جاية من Back
        if (performance.navigation.type === 2) {
            return; // 
        }

        var successEl = document.getElementById('successToast');
        if (successEl) {
            var successToast = new bootstrap.Toast(successEl);
            successToast.show();
        }
    });
</script>
