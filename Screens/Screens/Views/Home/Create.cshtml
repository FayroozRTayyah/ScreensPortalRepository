@model Screens.Models.Image

<style>
    body {
        font-family: 'Cairo', sans-serif;
        background: #f4f6f9;
    }

    /* HEADER */
    .page-header {
        text-align: center;
        margin: 40px 0 20px;
    }

        .page-header h1 {
            font-size: 30px;
            font-weight: bold;
            color: #85000d;
        }

        .page-header p {
            color: #888;
            font-size: 14px;
        }

    /* CARD */
    .card-form {
        max-width: 650px;
        margin: auto;
        background: #fff;
        padding: 30px;
        border-radius: 18px;
        box-shadow: 0 15px 40px rgba(0,0,0,0.08);
    }

        /* TITLE داخل الكارد */
        .card-form h2 {
            text-align: center;
            margin-bottom: 25px;
            color: #122e59;
        }

    /* INPUT GROUP */
    .form-group {
        margin-bottom: 18px;
    }

    /* LABEL */
    label {
        font-weight: 600;
        margin-bottom: 6px;
        display: block;
        color: #333;
    }

    /* INPUT */
    input {
        width: 100%;
        padding: 12px;
        border: 1px solid #ddd;
        border-radius: 10px;
        transition: 0.3s;
    }

        input:focus {
            border-color: #122e59;
            outline: none;
            box-shadow: 0 0 0 2px rgba(18,46,89,0.1);
        }

    /* IMAGE PREVIEW */
    .preview {
        margin-top: 12px;
        width: 100%;
        height: 220px;
        object-fit: cover;
        display: none;
        border-radius: 12px;
        border: 1px solid #eee;
    }

    /* BUTTON */
    .btn-save {
        width: 100%;
        padding: 14px;
        background: linear-gradient(135deg, #122e59, #1f4c8f);
        color: white;
        border: none;
        border-radius: 10px;
        font-weight: bold;
        margin-top: 15px;
        transition: 0.3s;
    }

        .btn-save:hover {
            background: linear-gradient(135deg, #27ae60, #2ecc71);
        }

    /* VALIDATION */
    .text-danger {
        font-size: 13px;
    }
</style>

<div class="page-header">
    <h1>@Model.screen?.screenName</h1>
    <p>إضافة صورة جديدة</p>
</div>

<div class="card-form">
    <h2>بيانات الصورة</h2>

    <form asp-action="Create" method="post" enctype="multipart/form-data">
       
        @Html.AntiForgeryToken()

        <div class="form-group">
            <label>العنوان</label>
            <input asp-for="imageTitle" />
        </div>
        <span asp-validation-for="imageTitle" class="text-danger"></span>
        <div class="form-group">
            <label>الوصف</label>
            <input asp-for="imageDescription" />
        </div>

        <div class="form-group">
            <label>اختيار الصورة</label>
            <input asp-for="ImageFile" type="file" accept="image/*" onchange="previewImage(event)" />
            <img id="imgPreview" class="preview" />
        </div>
        <hidden asp-for="imageBath" id="imageBath"></hidden>
     
   
        <span asp-validation-for="ImageFile" class="text-danger"></span>

        @* <div class="form-group">
            <label>الحالة</label>
            <input asp-for="image_status" type="number" />
        </div> *@

        <div class="form-group">
            <label>من تاريخ</label>
            <input asp-for="imagefromDate" type="date" />
        </div>

        <div class="form-group">
            <label>إلى تاريخ</label>
            <input asp-for="imagetoDate" class="form-control" type="date" />
        </div>

        <div class="form-group">
            <label>ترتيب الصورة</label>
            <input asp-for="imageOrder"  />

         </div>
      
       
        <button type="button" class="btn-save" onclick="confirmSave()">
            حفظ
        </button>
    </form>
</div>


<div class="modal fade" id="saveModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content shadow-lg border-0 rounded-4">

            <!-- Header -->
            <div class="modal-header border-0">
                <h5 class="modal-title fw-bold text-primary">
                    تأكيد الحفظ
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <!-- Body -->
            <div class="modal-body text-center py-4">

               

                <p class="mt-3 fs-6 text-secondary">
                    هل أنت متأكد أنك تريد حفظ هذه الصورة؟
                </p>

            </div>

            <!-- Footer -->
            <div class="modal-footer border-0 d-flex justify-content-center gap-2">

                <button class="btn btn-light px-4" data-bs-dismiss="modal">
                    لا
                </button>

                <button class="btn btn-primary px-4 fw-bold" onclick="saveItem()">
                    نعم، حفظ
                </button>

            </div>

        </div>
    </div>
</div>

<script>
    function previewImage(event) {

        var reader = new FileReader();
        reader.onload = function () {
            var img = document.getElementById("imgPreview");
            // const imageURL = URL.createObjectURL(img);
            img.src = reader.result;
           // document.getElementById("imageBath").value = img.imageBath.url;
           // document.getElementById("imageBath").value = img.imageBath;
            var imageBath =img.src;
             console.log("imageBath");
            console.log(imageBath);

            img.style.display = "block";
        }
        reader.readAsDataURL(event.target.files[0]);
    }
</script>

<script>

 

        

</script>

<script>
    function confirmSave() {


        let isValid = true;


        let title = document.querySelector("[name='imageTitle']");
        let desc = document.querySelector("[name='imageDescription']");
        let file = document.querySelector("[name='ImageFile']");
        let fromDate = document.querySelector("[name='imagefromDate']");
        let toDate = document.querySelector("[name='imagetoDate']");

     [title, desc, file, fromDate, toDate].forEach(el => {
            el.style.border = "1px solid #ddd";
        });

        // title validation
        if (title.value.trim() === "") {
            title.style.border = "2px solid red";
            isValid = false;
        }

        // description validation
        if (desc.value.trim() === "") {
            desc.style.border = "2px solid red";
            isValid = false;
        }


        // fromDate validation
        if(fromDate.value.trim() === ""){
            fromDate.style.border = "2px solid red";
            isValid = false;
        }

         // toDate validation
        if(toDate.value.trim() === ""){
            toDate.style.border = "2px solid red";
            isValid = false;
        }


        // date validation
        if (fromDate.value && toDate.value) {
            console.log(" date validation")
            if (new Date(fromDate.value) > new Date(toDate.value)) {
                fromDate.style.border = "2px solid red";
                toDate.style.border = "2px solid red";
                      toastr["error"]("تاريخ البداية يجب أن يكون قبل تاريخ النهاية", "", {
                            "closeButton": true,
                            "debug": false,
                            "newestOnTop": true,
                            "progressBar": true,
                            "positionClass": "toast-top-left",
                            "preventDuplicates": true,
                            "onclick": null,
                            "showDuration": "300",
                            "hideDuration": "1000",
                            "timeOut": "3000",
                            "extendedTimeOut": "1000",
                            "showEasing": "swing",
                            "hideEasing": "linear",
                            "showMethod": "fadeIn",
                            "hideMethod": "fadeOut"
                        })



                isValid = false;
            }
        }


         // image validation
        if (file.files.length === 0) {
            file.style.border = "2px solid red";
            isValid = false;
        }

       let allowedTypes = ["image/jpeg", "image/png", "image/jpg"];
    if (file.files.length > 0 && !allowedTypes.includes(file.files[0].type)) {

             toastr["error"]("يرجى اختيار صورة بصيغة JPG أو PNG فقط", "", {
                            "closeButton": true,
                            "debug": false,
                            "newestOnTop": true,
                            "progressBar": true,
                            "positionClass": "toast-top-left",
                            "preventDuplicates": true,
                            "onclick": null,
                            "showDuration": "300",
                            "hideDuration": "1000",
                            "timeOut": "3000",
                            "extendedTimeOut": "1000",
                            "showEasing": "swing",
                            "hideEasing": "linear",
                            "showMethod": "fadeIn",
                            "hideMethod": "fadeOut"
                        })

        file.style.border = "2px solid red";
        isValid = false;
    }

        let maxSize = 2 * 1024 * 1024;
    if (file.files.length > 0 && file.files[0].size > maxSize) {

         toastr["error"]("حجم الصورة يجب أن يكون أقل من 2MB", "", {
                            "closeButton": true,
                            "debug": false,
                            "newestOnTop": true,
                            "progressBar": true,
                            "positionClass": "toast-top-left",
                            "preventDuplicates": true,
                            "onclick": null,
                            "showDuration": "300",
                            "hideDuration": "1000",
                            "timeOut": "3000",
                            "extendedTimeOut": "1000",
                            "showEasing": "swing",
                            "hideEasing": "linear",
                            "showMethod": "fadeIn",
                            "hideMethod": "fadeOut"
                        })


        isValid = false;
    }

        // منع الإرسال إذا في خطأ
        if (!isValid) {
            e.preventDefault();
        }

        


        var modal = new bootstrap.Modal(document.getElementById('saveModal'));
        modal.show();
    }

    function saveItem() {
        document.querySelector("form").submit();
    }
</script>