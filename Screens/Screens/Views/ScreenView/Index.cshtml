@model List<Screens.Models.Image>

  <style>
    html, body {
        margin: 0;
        padding: 0;
        height: 100%;
    }

    /* السلايدر ياخذ كامل الشاشة */
    .owl-carousel,
    .owl-stage-outer,
    .owl-stage,
    .owl-item,
    .item {
        height: 100vh;
    }

        /* الصورة */
        .item img {
            width: 100%;
            height: 100vh;
            object-fit: cover;
        }

    /* إخفاء النقاط */
    .owl-dots {
        display: none;
    }

    .owl-carousel {
        display: block !important;
    }
  </style>

<div class="owl-carousel owl-theme owl-loaded">
    @foreach (var item in Model)
    {
        <div class="item">
            <img src="@("https://localhost:7094" + item.imageBath)"
               />
        </div>
    }
</div>

@section Scripts {
    <script>
               $(document).ready(function () {
            $(".owl-carousel").owlCarousel({
                items: 1,
                loop: true,
                autoplay: true,
                autoplayTimeout: 60000,
                autoplayHoverPause: false,
                nav: false,
                dots: false
            });
        });
    </script>
}