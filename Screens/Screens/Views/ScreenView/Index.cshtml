@model List<Screens.Models.Image>

  <style>
    html, body {
        margin: 0;
        padding: 0;
        height: 100%;
    }

    /* img {
        width: 100vw;
        height: 100vh;
    } */

    .owl-dots {
        display: none;
    }
  </style>

<div class="owl-carousel owl-theme">
    @foreach (var item in Model)
    {
        <div class="item">
            <img src="@("https://localhost:7094" + item.imageBath)"
               />
        </div>
    }
</div>

@section Scripts {
    <script>
          $(document).ready(function(){
            $(".owl-carousel").owlCarousel({
                items: 1,
                loop: true,
                autoplay: true,
                autoplayTimeout: 60000, // 1 minute
                autoplayHoverPause: false,
                nav: false,
            });
        });
    </script>
}