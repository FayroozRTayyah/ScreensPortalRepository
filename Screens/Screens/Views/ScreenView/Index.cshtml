@model List<Screens.Models.Image>

  <style>
    html, body {
        margin: 0;
        padding: 0;
        height: 100%;
    }

    img {
        width: 100vw;
        height: 100vh;
    }

    /* .owl-dots {
        display: none;
    } */
  </style>

<div class="owl-carousel owl-theme">
    @foreach (var item in Model)
    {
        <div class="item">
            <img src="@("https://localhost:7094" + item.imageBath)"
                 style="width:100%; height:450px; object-fit:cover; border-radius:10px;" />
        </div>
    }
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            $(".owl-carousel").owlCarousel({
                items: 1,
                loop: true,
                nav: false,
                dots: true,
                mouseDrag: true,
                touchDrag: true
            });
        });
    </script>
}